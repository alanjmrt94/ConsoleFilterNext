# Copia este archivo a .release.local para fijar JAVA_HOME en tu máquina.
# El script release.sh lo genera automáticamente al configurar Java.
#
# cp scripts/.release.local.example scripts/.release.local
#
# Recomendado (Forge oficial):
# export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
#
# Alternativa válida (compila OK en este proyecto):
# export JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
#
# export PATH="${JAVA_HOME}/bin:${PATH}"
