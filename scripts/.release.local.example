# Configuración local del entorno de desarrollo (no versionar)
# Copiar: cp scripts/.release.local.example scripts/.release.local
# El script release.sh también puede generar JAVA_HOME al configurar Java.

export JAVA_HOME="/usr/lib/jvm/java-1.21.0-openjdk-amd64"
export PATH="${JAVA_HOME}/bin:${PATH}"

# ─── Publicación de releases (menú 9 / ./scripts/release.sh publish) ─────────
#
# GitHub: autenticación vía `gh auth login` (no hace falta token aquí)
export GITHUB_REMOTE=origin
#
# CurseForge: https://console.curseforge.com → Account → API tokens
export CURSEFORGE_API_TOKEN="c7bbb4a0-..."
export CURSEFORGE_PROJECT_SLUG="consolefilternext"
export CURSEFORGE_PROJECT_ID=""   # opcional; ID numérico de CurseForge (vacío = resolver por slug)
#   No usar el nombre del proyecto; CurseForge usa IDs numéricos.
#
# Modrinth: https://modrinth.com/settings/account → Personal access tokens
#   El token debe tener permiso de subir versiones (VERSION_CREATE / upload).
export MODRINTH_TOKEN="mrp_..."
export MODRINTH_PROJECT_SLUG="consolefilternext"
# ID Base62 del proyecto (columna ID en Modrinth → Projects).
#   • Proyecto publicado: puede dejarse vacío; el script resuelve el ID por slug.
#   • Proyecto en draft: obligatorio — la API pública no expone el slug hasta aprobar.
#   • No usar el nombre visible (p. ej. "ConsoleFilterNext"); solo el ID Base62 (p. ej. tFqJGW2q).
export MODRINTH_PROJECT_ID=""
#
export RELEASE_TYPE="release"     # release | beta | alpha
